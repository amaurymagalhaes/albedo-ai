{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@bun/*": ["src/bun/*"],
      "@views/*": ["src/views/*"]
    },
    "skipLibCheck": true,
    "types": ["bun-types"]
  },
    "include": ["src/**/*", "electrobun.config.ts", "src/declarations.d.ts"]
}
